---
import { getCollection } from "astro:content";

import "../styles/global.css";
import { getLetterNavItems } from "../lib/letterUtils.js";

const {
  title = "Learn Letters",
  description = "A bilingual long-form reading site for shareholder letters.",
} = Astro.props;

const letterEntries = await getCollection("letters");
const partnerLetterEntries = await getCollection("partner-letters");
const specialLetterEntries = await getCollection("special-letters");
const shareholderNavEntries = getLetterNavItems(letterEntries);
const limitedPartnerNavEntries = getLetterNavItems(partnerLetterEntries, { hrefBase: "/partner-letters" });
const specialNavEntries = getLetterNavItems(specialLetterEntries, { hrefBase: "/special-letters" });
const currentPath = Astro.url.pathname;
const isShareholderNavActive = shareholderNavEntries.some((entry) => entry.href === currentPath);
const isLimitedPartnerNavActive = limitedPartnerNavEntries.some((entry) => entry.href === currentPath);
const isSpecialNavActive = specialNavEntries.some((entry) => entry.href === currentPath);
---

<!doctype html>
<html lang="zh-CN" data-view-mode="bilingual">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <button class="sidebar-toggle" aria-label="打开导航菜单">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <div class="sidebar-overlay"></div>
    <div class="site-shell">
      <aside class="site-sidebar">
         <a class="site-brand" href="/">
            <span class="site-brand__mark">◎</span>
            <span class="site-brand__text">
              <strong>巴菲特的信</strong>
              <small>Buffett Letters</small>
            </span>
          </a>
        <div class="site-sidebar__inner">
          <nav class="site-nav" aria-label="Primary">
            <a class:list={["site-nav__home", currentPath === "/" && "is-active"]} href="/">
              首页
            </a>
          </nav>

          <div class="site-directories">
            <details class="site-directory" open={isShareholderNavActive || !isLimitedPartnerNavActive}>
              <summary class="site-directory__heading">
                <span class="site-directory__heading-main">
                  <span class="site-directory__caret" aria-hidden="true">▾</span>
                  <span class="site-directory__title">伯克希尔股东信</span>
                </span>
                <span>{shareholderNavEntries.length}</span>
              </summary>

              <div class="site-directory__list">
                {shareholderNavEntries.map((entry) => (
                  <a class:list={["site-directory__item", currentPath === entry.href && "is-active"]} href={entry.href}>
                    {/* <span class="site-directory__year">{entry.year}</span> */}
                    <span class="site-directory__label">{entry.label}</span>
                  </a>
                ))}
              </div>
            </details>

            <details class="site-directory" open={isLimitedPartnerNavActive}>
              <summary class="site-directory__heading">
                <span class="site-directory__heading-main">
                  <span class="site-directory__caret" aria-hidden="true">▾</span>
                  <span class="site-directory__title">致合伙人的信</span>
                </span>
                <span>{limitedPartnerNavEntries.length}</span>
              </summary>

              <div class="site-directory__list">
                {limitedPartnerNavEntries.map((entry) => (
                  <a class:list={["site-directory__item", currentPath === entry.href && "is-active"]} href={entry.href}>
                    <span class="site-directory__label">{entry.label}</span>
                  </a>
                ))}
              </div>
            </details>

            <details class="site-directory" open={isSpecialNavActive}>
              <summary class="site-directory__heading">
                <span class="site-directory__heading-main">
                  <span class="site-directory__caret" aria-hidden="true">▾</span>
                  <span class="site-directory__title">特别信件</span>
                </span>
                <span>{specialNavEntries.length}</span>
              </summary>

              <div class="site-directory__list">
                {specialNavEntries.map((entry) => (
                  <a class:list={["site-directory__item", currentPath === entry.href && "is-active"]} href={entry.href}>
                    <span class="site-directory__label">{entry.label}</span>
                  </a>
                ))}
              </div>
            </details>
          </div>
        </div>
      </aside>

      <main class="page-shell">
        <div class="page-shell__inner">
          <slot />
        </div>
      </main>
    </div>
  </body>

  <script>
    const toggle = document.querySelector('.sidebar-toggle');
    const sidebar = document.querySelector('.site-sidebar');
    const overlay = document.querySelector('.sidebar-overlay');

    function openSidebar() {
      sidebar.classList.add('is-open');
      overlay.classList.add('is-visible');
    }

    function closeSidebar() {
      sidebar.classList.remove('is-open');
      overlay.classList.remove('is-visible');
    }

    toggle.addEventListener('click', openSidebar);
    overlay.addEventListener('click', closeSidebar);

    // Close sidebar when a nav link is clicked on mobile
    sidebar.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 720) closeSidebar();
      });
    });
  </script>
</html>
