<div class="lang-fab" data-lang-fab>
  <button
    type="button"
    class="lang-fab__trigger"
    data-lang-trigger
    aria-label="切换语言显示模式"
    aria-expanded="false"
  >
    <span class="lang-fab__icon" data-lang-icon>文</span>
    <span class="lang-fab__ring"></span>
  </button>

  <div class="lang-fab__menu" data-lang-menu aria-hidden="true">
    <button type="button" class="lang-fab__option is-active" data-view-mode-trigger="bilingual">
      <span class="lang-fab__label">双语</span>
      <span class="lang-fab__hint">Bilingual</span>
    </button>
    <button type="button" class="lang-fab__option" data-view-mode-trigger="en">
      <span class="lang-fab__label">English</span>
      <span class="lang-fab__hint">英文</span>
    </button>
    <button type="button" class="lang-fab__option" data-view-mode-trigger="zh">
      <span class="lang-fab__label">中文</span>
      <span class="lang-fab__hint">Chinese</span>
    </button>
  </div>
</div>

<script>
  const modes = ["bilingual", "en", "zh"];

  const iconMap = {
    bilingual: "文",
    en: "En",
    zh: "中",
  };

  function applyViewMode(mode) {
    const safeMode = modes.includes(mode) ? mode : "bilingual";
    document.documentElement.dataset.viewMode = safeMode;

    document.querySelectorAll("[data-view-mode-trigger]").forEach((button) => {
      const isActive = button.dataset.viewModeTrigger === safeMode;
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-pressed", String(isActive));
    });

    const icon = document.querySelector("[data-lang-icon]");
    if (icon) icon.textContent = iconMap[safeMode];

    window.localStorage.setItem("preferred-letter-view-mode", safeMode);
  }

  function setupViewModeToggle() {
    const preferredMode = window.localStorage.getItem("preferred-letter-view-mode") || "bilingual";
    applyViewMode(preferredMode);

    const fab = document.querySelector("[data-lang-fab]");
    const trigger = document.querySelector("[data-lang-trigger]");
    const menu = document.querySelector("[data-lang-menu]");

    if (!fab || !trigger || !menu) return;

    let isOpen = false;

    function toggleMenu(open) {
      isOpen = open;
      trigger.setAttribute("aria-expanded", String(open));
      menu.setAttribute("aria-hidden", String(!open));
      fab.classList.toggle("is-open", open);
    }

    trigger.addEventListener("click", () => toggleMenu(!isOpen));

    document.querySelectorAll("[data-view-mode-trigger]").forEach((button) => {
      button.addEventListener("click", () => {
        applyViewMode(button.dataset.viewModeTrigger);
        toggleMenu(false);
      });
    });

    document.addEventListener("click", (e) => {
      if (isOpen && !fab.contains(e.target)) {
        toggleMenu(false);
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) {
        toggleMenu(false);
        trigger.focus();
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupViewModeToggle, { once: true });
  } else {
    setupViewModeToggle();
  }
</script>
