---
import { renderRichText } from "../lib/renderRichText.js";

const { block } = Astro.props;
---

<article class="letter-block" id={block.id}>
  <div class="letter-block__body">
    <section
      class="letter-block__section"
      data-letter-language="en"
      data-note-scope
      data-block-id={block.id}
      data-language="en"
      aria-label={`English block ${block.id}`}
    >
      <div class="rich-text" data-note-content set:html={renderRichText(block.en)} />
    </section>

    <section
      class="letter-block__section"
      data-letter-language="zh"
      data-note-scope
      data-block-id={block.id}
      data-language="zh"
      aria-label={`Chinese block ${block.id}`}
    >
      <div class="rich-text" data-note-content set:html={renderRichText(block.zh)} />
    </section>
  </div>
</article>
