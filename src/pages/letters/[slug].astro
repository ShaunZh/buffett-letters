---
import { getCollection } from "astro:content";

import LetterBlock from "../../components/LetterBlock.astro";
import LetterNotes from "../../components/LetterNotes.astro";
import ViewModeToggle from "../../components/ViewModeToggle.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { filterPublishedLetters, sortLettersByDateDesc } from "../../lib/letterUtils.js";
import { parseLetterBlocks } from "../../lib/parseLetterBlocks.js";

export async function getStaticPaths() {
  const entries = sortLettersByDateDesc(filterPublishedLetters(await getCollection("letters")));

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const blocks = parseLetterBlocks(entry.body);
const sourceDocumentUrl = entry.data.pdfPath ?? entry.data.sourceUrl;
---

<BaseLayout title={`${entry.data.title_zh} | Learn Letters`}>
  <article class="letter-detail" data-letter-page data-letter-slug={entry.slug}>
    <a class="back-link" href="/">← 返回首页</a>

    <header class="letter-detail__header">
      <!-- <p class="letter-detail__eyebrow">{entry.data.type}</p> -->
      <div class="letter-detail__title-row">
        <h1 class="letter-detail__title">{entry.data.title_zh}</h1>
        {sourceDocumentUrl && (
          <a
            class="source-link source-link--inline"
            href={sourceDocumentUrl}
            target="_blank"
            rel="noreferrer"
            aria-label="查看原件"
            title="查看原件"
          >
            <svg
              class="source-link__icon"
              viewBox="0 0 24 24"
              width="22"
              height="22"
              aria-hidden="true"
            >
              <path
                d="M14 5h5v5m0-5-8 8M10 7H8a3 3 0 0 0-3 3v6a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3v-2"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.8"
              />
            </svg>
          </a>
        )}
      </div>

      <!-- <div class="letter-detail__meta">
        <time datetime={entry.data.date.toISOString()}>{entry.data.date.toLocaleDateString("zh-CN")}</time>
        <div class="tag-list">
          {entry.data.tags.map((tag) => (
            <a class="tag-chip tag-chip--interactive" href={`/tags/${tag}/`}>{tag}</a>
          ))}
        </div>
      </div> -->

      {entry.data.summary && <p class="letter-detail__summary">{entry.data.summary}</p>}
    </header>

    <ViewModeToggle />

    <section class="letter-blocks" aria-label="Letter content blocks">
      {blocks.map((block) => (
        <LetterBlock block={block} />
      ))}
    </section>
  </article>

  <LetterNotes />

  <script>
    import { setupReadingPosition } from "../../lib/readingPosition.js";
    setupReadingPosition();
  </script>
</BaseLayout>
