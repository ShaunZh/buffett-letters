---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("concepts", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Define concept order for prev/next navigation
const conceptOrder = [
  "intrinsic-value",
  "economic-moat",
  "margin-of-safety",
  "mr-market",
  "owner-earnings",
  "circle-of-competence",
  "long-term-thinking",
  "capital-allocation",
  "insurance-float",
  "concentrated-portfolio",
];

const allConcepts = await getCollection("concepts", ({ data }) => !data.draft);
const sortedConcepts = conceptOrder
  .map((slug) => allConcepts.find((c) => c.slug === slug))
  .filter(Boolean);

const currentIndex = sortedConcepts.findIndex((c) => c.slug === entry.slug);
const prevConcept = currentIndex > 0 ? sortedConcepts[currentIndex - 1] : null;
const nextConcept = currentIndex < sortedConcepts.length - 1 ? sortedConcepts[currentIndex + 1] : null;
---

<BaseLayout title={`${entry.data.title_zh}（${entry.data.title}）| 核心概念 | 巴菲特的信`}>
  <article class="concept-detail">
    <a class="back-link" href="/concepts/">← 全部核心概念</a>

    <header class="concept-detail__header">
      <div class="concept-detail__tag">核心概念</div>
      <h1 class="concept-detail__title">
        {entry.data.title_zh}
        <span class="concept-detail__title-en">{entry.data.title}</span>
      </h1>
    </header>

    <section class="concept-detail__body">
      <Content />
    </section>

    <nav class="concept-detail__nav">
      {prevConcept ? (
        <a href={`/concepts/${prevConcept.slug}/`} class="concept-detail__nav-link concept-detail__nav-link--prev">
          <span class="concept-detail__nav-arrow">←</span>
          <span class="concept-detail__nav-meta">上一个概念</span>
          <span class="concept-detail__nav-title">{prevConcept.data.title_zh}</span>
        </a>
      ) : <div />}
      {nextConcept ? (
        <a href={`/concepts/${nextConcept.slug}/`} class="concept-detail__nav-link concept-detail__nav-link--next">
          <span class="concept-detail__nav-arrow">→</span>
          <span class="concept-detail__nav-meta">下一个概念</span>
          <span class="concept-detail__nav-title">{nextConcept.data.title_zh}</span>
        </a>
      ) : <div />}
    </nav>
  </article>
</BaseLayout>

<style>
  .concept-detail {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: 2rem;
    font-family: ui-sans-serif, system-ui, sans-serif;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .concept-detail__header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .concept-detail__tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1rem;
    font-family: ui-sans-serif, system-ui, sans-serif;
  }

  .concept-detail__title {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .concept-detail__title-en {
    font-size: 0.55em;
    font-weight: 400;
    color: var(--muted);
    letter-spacing: 0.02em;
    font-family: ui-sans-serif, system-ui, sans-serif;
  }

  .concept-detail__body {
    line-height: 1.9;
    color: var(--text);
  }

  /* Markdown content styles */
  .concept-detail__body :global(h2) {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin: 3rem 0 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .concept-detail__body :global(h3) {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 2rem 0 0.75rem;
  }

  .concept-detail__body :global(p) {
    margin: 0 0 1.25rem;
  }

  .concept-detail__body :global(strong) {
    color: var(--text);
    font-weight: 700;
  }

  /* Quote blocks */
  .concept-detail__body :global(blockquote) {
    margin: 1.5rem 0;
    padding: 1.25rem 1.5rem;
    background: var(--accent-soft);
    border-left: 3px solid var(--accent);
    border-radius: 0 6px 6px 0;
    color: var(--text);
    font-style: italic;
    font-size: 0.97rem;
    line-height: 1.85;
  }

  .concept-detail__body :global(blockquote p) {
    margin: 0 0 0.75rem;
  }

  .concept-detail__body :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Horizontal rules */
  .concept-detail__body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  /* Letter links */
  .concept-detail__body :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(138, 75, 47, 0.3);
    transition: border-color 0.2s;
  }

  .concept-detail__body :global(a:hover) {
    border-color: var(--accent);
  }

  /* Navigation */
  .concept-detail__nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .concept-detail__nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, border-color 0.2s;
  }

  .concept-detail__nav-link:hover {
    background: #fff;
    border-color: var(--accent);
  }

  .concept-detail__nav-link--next {
    text-align: right;
    align-items: flex-end;
  }

  .concept-detail__nav-arrow {
    font-size: 1.2rem;
    color: var(--accent);
  }

  .concept-detail__nav-meta {
    font-size: 0.72rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: ui-sans-serif, system-ui, sans-serif;
  }

  .concept-detail__nav-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }
</style>
